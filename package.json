{
  "name": "postmaster",
  "version": "0.5.0",
  "description": "Local MCP server for macOS Mail.app + Calendar (privacy-first, runs on the user's machine)",
  "license": "MIT OR Apache-2.0",
  "author": "Nikko & Co LLC <nikkonco.llc@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeoxyz-jpg/postmaster"
  },
  "type": "module",
  "bin": {
    "postmaster": "dist/index.js",
    "postmaster-diagnose": "dist/diagnose.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "LICENSE-MIT",
    "LICENSE-APACHE",
    "NOTICE",
    "README.md"
  ],
  "os": [
    "darwin"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/mail/jxa dist/calendar/jxa && cp src/mail/jxa/*.js dist/mail/jxa/ && cp src/calendar/jxa/*.js dist/calendar/jxa/",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "diagnose": "node dist/diagnose.js",
    "dev": "tsc --watch",
    "pack": "bash scripts/pack-mcpb.sh"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
